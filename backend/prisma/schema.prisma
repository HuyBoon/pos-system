generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Quản lý nhân viên thu ngân/Admin
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(STAFF)
  orders    Order[]  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Danh mục sản phẩm (Đồ uống, Đồ ăn nhẹ...)
model Category {
  id        Int       @id @default(autoincrement())
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 3. Sản phẩm
model Product {
  id          Int         @id @default(autoincrement())
  name        String
  price       Float
  stock       Int         @default(0) // Số lượng tồn kho
  barcode     String?     @unique     // Hỗ trợ quét mã vạch sau này
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// 4. Hóa đơn tổng
model Order {
  id           Int         @id @default(autoincrement())
  totalAmount  Float       // Tổng tiền cuối cùng khách phải trả
  status       OrderStatus @default(COMPLETED)
  customerName String?     // Tên khách hàng (mặc định Khách lẻ)
  tableId      Int?        // Lưu lại id bàn
  table        Table?      @relation(fields: [tableId], references: [id])
  staffId      Int
  staff        User        @relation(fields: [staffId], references: [id])
  items        OrderItem[]
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
}

// 5. Chi tiết từng món trong hóa đơn
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   // Giá chốt tại thời điểm bán
}

// 6. Quản lý bàn
model Table {
  id             Int         @id @default(autoincrement())
  name           String
  seats          Int         @default(4)
  status         TableStatus @default(AVAILABLE)
  currentOrderId Int?        // Lưu ID đơn hàng đang phục vụ nếu có
  orders         Order[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
}

enum Role {
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
}