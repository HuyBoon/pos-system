generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// 1. Quản lý nhân viên thu ngân/Admin
model User {
  id        Int      @id @default(autoincrement())
  username  String   @unique
  password  String
  role      Role     @default(STAFF)
  orders    Order[]  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// 2. Danh mục sản phẩm (Đồ uống, Đồ ăn nhẹ...)
model Category {
  id        Int       @id @default(autoincrement())
  name      String
  products  Product[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

// 3. Sản phẩm
model Product {
  id          Int         @id @default(autoincrement())
  name        String
  price       Float
  stock       Int         @default(0) // Số lượng tồn kho
  barcode     String?     @unique     // Hỗ trợ quét mã vạch sau này
  categoryId  Int
  category    Category    @relation(fields: [categoryId], references: [id])
  orderItems  OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// 4. Hóa đơn tổng
model Order {
  id          Int         @id @default(autoincrement())
  totalAmount Float       // Tổng tiền cuối cùng khách phải trả
  status      OrderStatus @default(COMPLETED)
  tableId     Int?        // Lưu lại id bàn (Bàn 1, Bàn 2...)
  staffId     Int
  staff       User        @relation(fields: [staffId], references: [id])
  items       OrderItem[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt
}

// 5. Chi tiết từng món trong hóa đơn
model OrderItem {
  id        Int     @id @default(autoincrement())
  orderId   Int
  order     Order   @relation(fields: [orderId], references: [id])
  productId Int
  product   Product @relation(fields: [productId], references: [id])
  quantity  Int
  price     Float   // Giá chốt tại thời điểm bán (tránh lỗi lệch doanh thu khi đổi giá sản phẩm sau này)
}

enum Role {
  ADMIN
  STAFF
}

enum OrderStatus {
  PENDING
  COMPLETED
  CANCELLED
}